<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Required because the bundled Python backend loads dynamic libraries
         (numpy, torch, lancedb, etc.) that the OS can't pre-validate. -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Microphone: dictation via Whisper (matches NSMicrophoneUsageDescription). -->
    <key>com.apple.security.device.audio-input</key>
    <true/>

    <!-- User-selected file I/O for document uploads, scan dialogs, etc. -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>

    <!-- Outbound network access (Ollama, Whisper, HuggingFace downloads, etc.). -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- Inbound network access: capture server listens on :8443 for phone-based
         document scanning (QR Handoff). -->
    <key>com.apple.security.network.server</key>
    <true/>

    <!-- Allow the app to launch the localbook-backend sidecar.
         Without this, Hardened Runtime blocks child procs. -->
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
</dict>
</plist>
