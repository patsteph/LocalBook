<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- TCC tracks camera permission by bundle identifier. Without this,
         the sidecar inherits permission attribution from its parent
         (LocalBook.app) inconsistently across macOS versions. -->
    <key>CFBundleIdentifier</key>
    <string>com.localbook.continuity-camera</string>
    <key>CFBundleName</key>
    <string>LocalBook Continuity Camera Helper</string>
    <key>CFBundleDisplayName</key>
    <string>LocalBook Scan</string>
    <key>CFBundleExecutable</key>
    <string>continuity-camera</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>LSMinimumSystemVersion</key>
    <string>14.0</string>

    <!-- Camera permission prompt text. Shown the first time the sidecar
         calls AVCaptureDevice.requestAccess(for: .video). -->
    <key>NSCameraUsageDescription</key>
    <string>LocalBook needs camera access to capture documents and photos from your iPhone via Continuity Camera.</string>

    <!-- Critical: macOS 14+ AVCaptureDevice.DiscoverySession returns zero
         Continuity Camera devices unless this key is present and true. -->
    <key>NSCameraUseContinuityCameraDeviceType</key>
    <true/>

    <!-- LSUIElement = 1 keeps the sidecar out of the Dock; we still get a
         window because applicationDidFinishLaunching calls
         setActivationPolicy(.regular) at the moment we need foreground. -->
    <key>LSUIElement</key>
    <true/>
</dict>
</plist>
