# Curator phase verifier scripts (local-only, regenerated each phase)
backend/scripts/verify_phase*.py

# Code signing + notarization artifacts (NEVER commit to git)
# Certificate/keystore files — should only ever live in macOS keychain
*.p12
*.pfx
*.cer
*.crt
*.der
*.provisionprofile
*.mobileprovision
certs/
certificates/
.certificates/
# Notarization submission zips (intermediate files)
LocalBook-notary.zip
*-notary.zip
# Signing-identity convenience file (if any maintainer chooses to use one)
.signing.env

# Sidecar build outputs (universal binary is regenerated on every build)
src-tauri/binaries/
src-tauri/tools/continuity-camera/dist/

# Graphify
graphify-out/

# Extension manifest signing key — generates a deterministic extension ID
# (so the backend can pin its CORS allowlist + Origin-checked bootstrap).
# Private key MUST stay local — leaking it lets anyone publish an extension
# under our ID. Public key (the base64 string) is embedded in the manifest
# at build time. P0.1d (2026-05-15).
extension/.key.pem

# Build/coverage profiling artifacts (regenerable; never commit)
*.profraw

